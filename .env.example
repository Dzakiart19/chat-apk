# Server Configuration
PORT=5000
NODE_ENV=production

# App Domain (used for CORS and manifest generation)
# Set this to your deployment domain (e.g., dzeck-ai.example.com)
APP_DOMAIN=

# Expo Public Domain (used by the mobile app to connect to the API)
# Same as APP_DOMAIN for production deployments
EXPO_PUBLIC_DOMAIN=

# Optional: Custom API port for local development (default: 5000)
# EXPO_PUBLIC_API_PORT=5000

# CORS: Additional allowed origins (comma-separated)
# Example: https://myapp.com,https://admin.myapp.com
CORS_ORIGINS=

# Replit-specific (auto-set by Replit, not needed for standalone deployment)
# REPLIT_DEV_DOMAIN=
# REPLIT_DOMAINS=

# Agent Configuration
# Model to use for agent mode (default: gpt-4o-mini via g4f)
# AGENT_MODEL=gpt-4o-mini

# OpenAI-compatible API (optional, overrides g4f when set)
# OPENAI_API_KEY=sk-...
# OPENAI_API_BASE=https://api.openai.com/v1

# MCP Server Configuration (optional)
# MCP_SERVER_URL=http://localhost:3001

# Database (optional, for future user management features)
# DATABASE_URL=postgresql://user:password@localhost:5432/dzeck_ai
