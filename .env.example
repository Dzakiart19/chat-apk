# ─── Airforce API Configuration ───────────────────────────────────────────────
# Required: API key for https://api.airforce/v1/chat/completions
AIRFORCE_API_KEY=sk-air-your-key-here

# Optional: Override the default API URL
# AIRFORCE_API_URL=https://api.airforce/v1/chat/completions

# ─── Server Configuration ─────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ─── App Domain ───────────────────────────────────────────────────────────────
# Set this to your deployment domain (e.g., dzeck-ai.example.com)
APP_DOMAIN=

# Expo Public Domain (used by the mobile app to connect to the API)
# Same as APP_DOMAIN for production deployments
EXPO_PUBLIC_DOMAIN=

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Additional allowed origins (comma-separated)
# Example: https://myapp.com,https://admin.myapp.com
CORS_ORIGINS=

# ─── Agent Configuration ──────────────────────────────────────────────────────
# Model to use for agent mode (default: gpt-4o-mini)
# AGENT_MODEL=gpt-4o-mini

# ─── MCP Server (optional) ────────────────────────────────────────────────────
# MCP_SERVER_URL=http://localhost:3001

# ─── Database (optional) ──────────────────────────────────────────────────────
# DATABASE_URL=postgresql://user:password@localhost:5432/dzeck_ai
